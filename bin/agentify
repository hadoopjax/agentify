#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
AGENTIFY_ROOT="${AGENTIFY_INSTALL_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
LIB_DIR="$AGENTIFY_ROOT/lib"
CONTROL_PLANE="$LIB_DIR/control_plane.py"
AGENT_ENV_FILE="${AGENTIFY_ENV_FILE:-.agentify/agent.env}"

# Ensure npm global bin is in PATH (for codex, etc.)
if command -v npm > /dev/null 2>&1; then
  _npm_bin="$(npm prefix -g 2>/dev/null)/bin"
  [[ ":$PATH:" == *":$_npm_bin:"* ]] || export PATH="$_npm_bin:$PATH"
fi

load_env_file() {
  local env_file="$1"
  if [ ! -f "$env_file" ]; then
    return 0
  fi

  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    case "$line" in
      ''|\#*)
        continue
        ;;
    esac

    if [[ "$line" == export[[:space:]]* ]]; then
      line="${line#export }"
    fi

    if [[ "$line" != *=* ]]; then
      continue
    fi

    local key="${line%%=*}"
    local value="${line#*=}"

    if [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      continue
    fi

    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value="${value:1:${#value}-2}"
    fi

    printf -v "$key" '%s' "$value"
    export "$key"
  done < "$env_file"
}

# Load agent-only environment without touching the app's .env.
[ -f "$AGENT_ENV_FILE" ] && load_env_file "$AGENT_ENV_FILE"

if [ -z "${GIT_CONFIG_GLOBAL:-}" ] && [ -d "${HOME}/.gitconfig" ]; then
  export GIT_CONFIG_GLOBAL="${HOME}/.config/agentify/gitconfig"
  mkdir -p "$(dirname "$GIT_CONFIG_GLOBAL")"
  touch "$GIT_CONFIG_GLOBAL"
fi

# Colors
C_RESET="\033[0m"
C_DIM="\033[2m"
C_BOLD="\033[1m"
C_TEAL="\033[38;5;43m"
C_YELLOW="\033[38;5;222m"

DASHBOARD_PORT="${DASHBOARD_PORT:-4242}"
DASHBOARD_HOST="${DASHBOARD_HOST:-127.0.0.1}"
DASHBOARD_PID=""

usage() {
  cat <<'EOF'
Usage: agentify <command> [options]

Commands:
  run          Start the agent loop (from inside a git repo)
  update       Update this agentify checkout to the remote default branch
  plan "desc"  Plan an epic (Claude + GPT-5.4 dialectic)
  group        Group existing issues into epic proposals
  manage N     Run the management agent for a stuck issue
  manage --pr N  Adopt and manage an existing blocked PR
  approve ID   Approve all proposed issues for an epic
  triage       Review existing issues and assign to agent or skip
  init         Create agent/agent-wip/agent-skip labels
  test         Create a test issue to trigger the loop
  dashboard    Open just the dashboard
  status       Show current state + recent activity

Options:
  --max-runs N         Stop after N completed runs (0 = unlimited)
  --poll N             Seconds between idle checks (default: 60)
  --port N             Dashboard port (default: 4242)
  --host HOST          Dashboard bind host (default: 127.0.0.1)
  --codex-model M      Codex model (default: gpt-5.4)
  --codex-effort L     Reasoning effort: low, medium, high (default: high)
  --manager-model M    Manager model (default: gpt-5.4)
  --manager-effort L   Manager reasoning effort (default: high)
  --pr N               Pull request number/URL for `manage`
  --claude-model M     Claude model (default: claude-opus-4-6)
  --concurrency N      Parallel workers (default: 3)
  --self-repo OWNER/REPO  Agentify repo for self-healing error reports
  --no-dashboard       Skip the dashboard
EOF
  exit 1
}

cleanup() {
  printf "\n  ${C_DIM}stopping workers...${C_RESET}\n"
  # Kill all worker processes
  for pidfile in .agentify/workers/*.pid; do
    [ -f "$pidfile" ] || continue
    kill "$(cat "$pidfile")" 2>/dev/null || true
  done
  [ -n "$DASHBOARD_PID" ] && kill "$DASHBOARD_PID" 2>/dev/null
  printf "  ${C_DIM}agentify stopped${C_RESET}\n\n"
  exit 0
}

require_repo() {
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Not in a git repo. cd into one first."
    exit 1
  fi
}

require_tools() {
  local missing=()
  for cmd in gh claude jq node; do
    command -v "$cmd" > /dev/null 2>&1 || missing+=("$cmd")
  done
  if [ ${#missing[@]} -gt 0 ]; then
    echo "Missing: ${missing[*]}"
    exit 1
  fi
  # Codex is optional at startup — warn but don't block
  if ! command -v codex > /dev/null 2>&1; then
    printf "  ${C_DIM}├─${C_RESET} ${C_YELLOW}warning: codex not in PATH — workers will fail until installed${C_RESET}\n"
  fi
}

require_gh_auth() {
  if gh auth status > /dev/null 2>&1; then
    return 0
  fi
  if [ -n "${GH_TOKEN:-}" ] && env -u GH_TOKEN gh auth status > /dev/null 2>&1; then
    unset GH_TOKEN
    return 0
  fi
  echo "GitHub auth is missing or invalid. Set GH_TOKEN for the agent environment."
  exit 1
}

ensure_git_transport_auth() {
  if ! gh auth setup-git > /dev/null 2>&1; then
    echo "Git transport auth setup failed."
    exit 1
  fi
}

ensure_git_identity() {
  local name="${AGENT_GIT_NAME:-agentify}"
  local email="${AGENT_GIT_EMAIL:-agentify@local}"

  git config --global user.name "$name"
  git config --global user.email "$email"
}

ensure_codex_auth() {
  if [ -z "${OPENAI_API_KEY:-}" ]; then
    printf "  ${C_DIM}├─${C_RESET} ${C_YELLOW}warning: OPENAI_API_KEY not set — codex workers will fail${C_RESET}\n"
    return 0
  fi

  if ! command -v codex > /dev/null 2>&1; then
    return 0
  fi

  if ! printf '%s' "$OPENAI_API_KEY" | codex login --with-api-key > /dev/null 2>&1; then
    echo "Codex auth setup failed."
    exit 1
  fi
}

cmd_init() {
  require_repo
  local repo
  repo=$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null)
  echo "Setting up agentify for $repo..."
  mkdir -p .agentify

  if gh label list 2>/dev/null | grep -q "^agent	"; then
    echo "  Label 'agent' already exists"
  else
    gh label create agent --description "Agent loop will pick this up" --color "7C3AED"
    echo "  Label 'agent' created"
  fi

  if gh label list 2>/dev/null | grep -q "agent-wip"; then
    echo "  Label 'agent-wip' already exists"
  else
    gh label create agent-wip --description "Agent is working on this" --color "D4C5F9"
    echo "  Label 'agent-wip' created"
  fi

  if gh label list 2>/dev/null | grep -q "agent-skip"; then
    echo "  Label 'agent-skip' already exists"
  else
    gh label create agent-skip --description "Triaged — not for the agent" --color "D1D5DB"
    echo "  Label 'agent-skip' created"
  fi

  echo ""
  if [ ! -f "$AGENT_ENV_FILE" ]; then
    printf "OPENAI_API_KEY=\nANTHROPIC_API_KEY=\nGH_TOKEN=\n" > "$AGENT_ENV_FILE"
    echo "Created $AGENT_ENV_FILE"
  fi
  echo ""
  echo "Done. Label issues with 'agent', then run: agentify run"
  echo "Or run: agentify triage   to review existing issues"
}

cmd_test() {
  require_repo
  local url
  url=$(gh issue create \
    --title "Test: Add a CONTRIBUTORS.md file" \
    --body "Create a CONTRIBUTORS.md listing the repo owner. This is a test of the agent loop." \
    --label "agent")
  echo "Test issue created: $url"
  echo "Start the loop: agentify run"
}

cmd_status() {
  require_repo
  if [ -f ".agentify/state.db" ]; then
    echo "State:"
    python3 "$CONTROL_PLANE" event-list --after 0 | jq '.'
    echo ""
  fi

  echo "Agent issues:"
  gh issue list --label agent --state all --limit 10 2>/dev/null || true
  echo ""
  echo "Agent PRs:"
  gh pr list --search "head:agent/" --state all --limit 10 2>/dev/null || true
}

cmd_dashboard() {
  # dashboard is just an alias for run — no reason to view without working
  cmd_run
}

default_branch_for_remote() {
  local repo_root="$1"
  local branch=""

  branch="$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')" || true
  if [ -n "$branch" ]; then
    printf '%s\n' "$branch"
    return 0
  fi

  branch="$(git -C "$repo_root" ls-remote --symref origin HEAD 2>/dev/null | awk '/^ref:/ {sub("refs/heads/","",$2); print $2; exit}')" || true
  if [ -n "$branch" ]; then
    printf '%s\n' "$branch"
    return 0
  fi

  return 1
}

checkout_branch_if_needed() {
  local repo_root="$1"
  local branch="$2"

  if [ -n "$(git -C "$repo_root" branch --show-current)" ] && [ "$(git -C "$repo_root" branch --show-current)" = "$branch" ]; then
    return 0
  fi

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_root" checkout "$branch"
  else
    git -C "$repo_root" checkout -B "$branch" --track "origin/$branch"
  fi
}

cmd_update() {
  if ! command -v git > /dev/null 2>&1; then
    echo "Missing: git"
    exit 1
  fi

  if ! git -C "$AGENTIFY_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
    echo "agentify update only works when agentify was installed from a git checkout."
    echo "Install root: $AGENTIFY_ROOT"
    exit 1
  fi

  if ! git -C "$AGENTIFY_ROOT" remote get-url origin > /dev/null 2>&1; then
    echo "No origin remote is configured for the agentify checkout at:"
    echo "  $AGENTIFY_ROOT"
    exit 1
  fi

  if [ -n "$(git -C "$AGENTIFY_ROOT" status --porcelain)" ]; then
    echo "Refusing to update because the agentify checkout has local changes:"
    echo "  $AGENTIFY_ROOT"
    echo "Commit, stash, or discard them first."
    exit 1
  fi

  local default_branch current_branch old_rev new_rev
  default_branch="$(default_branch_for_remote "$AGENTIFY_ROOT")" || {
    echo "Couldn't determine the default branch for origin."
    exit 1
  }

  current_branch="$(git -C "$AGENTIFY_ROOT" branch --show-current)"
  old_rev="$(git -C "$AGENTIFY_ROOT" rev-parse --short HEAD)"

  echo "Updating agentify in $AGENTIFY_ROOT"
  echo "Fetching origin/$default_branch..."
  git -C "$AGENTIFY_ROOT" fetch origin "$default_branch"

  if [ "$current_branch" != "$default_branch" ]; then
    if [ -n "$current_branch" ]; then
      echo "Switching installed checkout from $current_branch to $default_branch"
    else
      echo "Switching installed checkout from detached HEAD to $default_branch"
    fi
    checkout_branch_if_needed "$AGENTIFY_ROOT" "$default_branch"
  fi

  git -C "$AGENTIFY_ROOT" pull --ff-only origin "$default_branch"
  new_rev="$(git -C "$AGENTIFY_ROOT" rev-parse --short HEAD)"

  if [ "$old_rev" = "$new_rev" ]; then
    echo "agentify is already up to date at $new_rev"
  else
    echo "agentify updated: $old_rev -> $new_rev"
  fi
}

cmd_run() {
  require_repo
  require_tools
  ensure_codex_auth
  require_gh_auth
  ensure_git_transport_auth
  ensure_git_identity

  # Start dashboard
  if [ "$NO_DASHBOARD" != "true" ]; then
    mkdir -p .agentify
    python3 "$CONTROL_PLANE" init > /dev/null
    export AGENTIFY_ADMIN_TOKEN="${AGENTIFY_ADMIN_TOKEN:-$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(24))
PY
)}"

    AGENTIFY_DIR=".agentify" AGENTIFY_HOST="$DASHBOARD_HOST" python3 "$LIB_DIR/dashboard.py" "$DASHBOARD_PORT" --host "$DASHBOARD_HOST" &
    DASHBOARD_PID=$!
    printf "  ${C_DIM}├─${C_RESET} dashboard: ${C_TEAL}http://${DASHBOARD_HOST}:${DASHBOARD_PORT}${C_RESET}\n"

    if command -v open > /dev/null 2>&1 && { [ "$DASHBOARD_HOST" = "127.0.0.1" ] || [ "$DASHBOARD_HOST" = "localhost" ]; }; then
      sleep 0.3 && open "http://${DASHBOARD_HOST}:$DASHBOARD_PORT" 2>/dev/null &
    fi
  fi

  trap cleanup SIGINT SIGTERM

  bash "$LIB_DIR/run-loop.sh"
}

# -- Parse args --
COMMAND=""
POSITIONAL_ARGS=()
MAX_RUNS=0
POLL_INTERVAL=60
MAX_CONCURRENT=3
NO_DASHBOARD="false"
CODEX_MODEL="gpt-5.4"
CODEX_EFFORT="high"
MANAGER_MODEL="gpt-5.4"
MANAGER_EFFORT="high"
MANAGE_PR=""
CLAUDE_MODEL="claude-opus-4-6"

while [[ $# -gt 0 ]]; do
  case "$1" in
    run|init|test|dashboard|status|update|plan|group|manage|approve|triage) COMMAND="$1"; shift ;;
    --max-runs)      shift; MAX_RUNS="$1"; shift ;;
    --poll)          shift; POLL_INTERVAL="$1"; shift ;;
    --port)          shift; DASHBOARD_PORT="$1"; shift ;;
    --host)          shift; DASHBOARD_HOST="$1"; shift ;;
    --concurrency)   shift; MAX_CONCURRENT="$1"; shift ;;
    --codex-model)   shift; CODEX_MODEL="$1"; shift ;;
    --codex-effort)  shift; CODEX_EFFORT="$1"; shift ;;
    --manager-model) shift; MANAGER_MODEL="$1"; shift ;;
    --manager-effort) shift; MANAGER_EFFORT="$1"; shift ;;
    --pr)            shift; MANAGE_PR="$1"; shift ;;
    --claude-model)  shift; CLAUDE_MODEL="$1"; shift ;;
    --self-repo)     shift; AGENTIFY_SELF_REPO="$1"; shift ;;
    --no-dashboard)  NO_DASHBOARD="true"; shift ;;
    -h|--help) usage ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

export MAX_RUNS POLL_INTERVAL MAX_CONCURRENT CODEX_MODEL CODEX_EFFORT MANAGER_MODEL MANAGER_EFFORT CLAUDE_MODEL AGENTIFY_SELF_REPO AUTO_GROUP_COOLDOWN_SECONDS AUTO_IDEATION_COOLDOWN_SECONDS DASHBOARD_HOST

[ -z "$COMMAND" ] && COMMAND="run"

cmd_plan() {
  require_repo
  require_tools
  require_gh_auth
  local desc="${1:-}"
  if [ -z "$desc" ]; then
    echo "Usage: agentify plan \"description of the feature\""
    exit 1
  fi

  mkdir -p .agentify
  python3 "$CONTROL_PLANE" init > /dev/null

  source "$LIB_DIR/loop.sh"
  source "$LIB_DIR/planner.sh"
  plan_epic "$desc"
}

cmd_group() {
  require_repo
  require_tools
  require_gh_auth

  mkdir -p .agentify
  python3 "$CONTROL_PLANE" init > /dev/null

  source "$LIB_DIR/loop.sh"
  source "$LIB_DIR/planner.sh"
  group_existing_issues
}

cmd_approve() {
  require_repo
  local epic_id="${1:-}"
  if [ -z "$epic_id" ]; then
    echo "Usage: agentify approve <epic-id>"
    echo ""
    echo "Active epics:"
    python3 "$CONTROL_PLANE" epic-list | jq -r '.epics[]? | "  \(.id)  \(.title)  (\(.status), \([.proposals[] | select(.status == "pending")] | length) pending)"'
    exit 1
  fi

  mkdir -p .agentify
  python3 "$CONTROL_PLANE" init > /dev/null

  source "$LIB_DIR/loop.sh"
  source "$LIB_DIR/planner.sh"
  approve_all "$epic_id"
}

cmd_triage() {
  require_repo
  require_gh_auth
  source "$LIB_DIR/loop.sh"
  source "$LIB_DIR/planner.sh"

  echo "Fetching open issues..."
  local untriaged
  untriaged=$(existing_group_candidates | jq -c '[.[] | {number, title}]')

  local count=$(echo "$untriaged" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No untriaged issues found."
    echo "All open issues already have agent, agent-wip, or agent-skip labels."
    return 0
  fi

  echo ""
  printf "  ${C_BOLD}$count untriaged issues:${C_RESET}\n\n"
  echo "$untriaged" | jq -r '.[] | "  #\(.number)  \(.title)"'
  echo ""
  echo "Open the dashboard to triage: http://localhost:${DASHBOARD_PORT}"
  echo "Or label manually:  gh issue edit <num> --add-label agent"
}

cmd_manage() {
  require_repo
  require_tools
  ensure_codex_auth
  require_gh_auth
  ensure_git_transport_auth
  ensure_git_identity
  local num="${1:-}"
  if [ -z "$num" ] && [ -z "$MANAGE_PR" ]; then
    echo "Usage: agentify manage <issue-number>"
    echo "   or: agentify manage --pr <pull-request>"
    exit 1
  fi

  mkdir -p .agentify
  python3 "$CONTROL_PLANE" init > /dev/null

  source "$LIB_DIR/loop.sh"
  if [ -n "$MANAGE_PR" ]; then
    num=$(adopt_pr_for_management "$MANAGE_PR" "$num") || {
      echo "Unable to adopt PR $MANAGE_PR for management"
      exit 1
    }
  fi
  manage_issue "$num" || {
    echo "Unable to manage $num"
    exit 1
  }
}

# Grab remaining positional arg for plan/approve
POSITIONAL=""
case "$COMMAND" in
  plan|approve|manage) POSITIONAL="${POSITIONAL_ARGS[0]:-}" ;;
esac

case "$COMMAND" in
  run)       cmd_run ;;
  update)    cmd_update ;;
  plan)      cmd_plan "$POSITIONAL" ;;
  group)     cmd_group ;;
  manage)    cmd_manage "$POSITIONAL" ;;
  approve)   cmd_approve "$POSITIONAL" ;;
  triage)    cmd_triage ;;
  init)      cmd_init ;;
  test)      cmd_test ;;
  dashboard) cmd_dashboard ;;
  status)    cmd_status ;;
  *)         usage ;;
esac
